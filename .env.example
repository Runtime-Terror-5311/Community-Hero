# GEMINI_API_KEY: Required for Gemini AI Triaging Gatekeeper.
# AI Studio automatically injects this at runtime from user secrets.
# To get one: Visit https://aistudio.google.com/ and click "Get API Key".
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# MONGODB_URI: Optional. A standard MongoDB connection string (e.g., MongoDB Atlas).
# If provided, this is used for multi-user distributed database storage across containers/devices.
# If omitted, the server automatically defaults to the high-fidelity persistent local JSON DB (data/db.json).
# To get one: Visit https://www.mongodb.com/cloud/atlas, create a free cluster, and get your connection string.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.mongodb.net/community_hero?retryWrites=true&w=majority"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
# Used for callback endpoints, asset links, and self-referential hooks.
APP_URL="YOUR_APP_URL"

# CLOUDINARY: Required for Cloudinary image uploading.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=



